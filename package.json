{
  "name": "@instawp/mcp-wp",
  "version": "0.0.5",
  "description": "A Model Context Protocol server for WordPress with contract-driven custom content types.",
  "type": "module",
  "main": "./build/server.js",
  "exports": "./build/server.js",
  "bin": {
    "mcp-wp": "./build/server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node ./build/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "tsx --test test/*.test.ts",
    "clean": "rimraf build",
    "prepare": "npm run build"
  },
  "keywords": [
    "wordpress",
    "mcp",
    "server",
    "claude",
    "ai",
    "instawp",
    "custom-post-types",
    "eventon"
  ],
  "author": "Claude",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.4.1",
    "axios": "^1.6.7",
    "dotenv": "^17.4.1",
    "form-data": "^4.0.5",
    "fs-extra": "^11.2.0",
    "marked": "^17.0.3",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.7.1",
    "typescript": "^6.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ]
}
